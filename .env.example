# Gemini API Key (Required for LLM nodes)
GEMINI_API_KEY=your_gemini_api_key_here

# NVD API Key (Optional but recommended for NVD queries to avoid rate limits)
NVD_API_KEY=your_nvd_api_key_here

# GitHub Token (Optional but recommended for GitHub PoC searches to avoid rate limits)
GITHUB_TOKEN=your_github_token_here
